{
  "openapi": "3.0.0",
  "info": {
    "title": "Payment Options API",
    "description": "API per recuperare le opzioni di pagamento per un determinato ente e un determinato avviso.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.dev.platform.pagopa.it/mocker/v1"
    },
    {
      "url": "{basePath}",
      "description": "Base path dell'ente",
      "variables": {
        "basePath": {
          "default": "https://api.dev.platform.pagopa.it/mocker/v1"
        }
      }
    }
  ],
  "paths": {
    "/payment-options/organizations/{paTaxCode}/notices/{noticeId}": {
      "post": {
        "summary": "Recupera le opzioni di pagamento per un avviso specifico.",
        "description": "Restituisce le opzioni di pagamento per un determinato avviso, specificato dal parametro `noticeId`, per un ente identificato dal codice fiscale `paTaxCode` .",
        "parameters": [
          {
            "name": "paTaxCode",
            "in": "path",
            "required": true,
            "description": "Codice fiscale dell'ente.",
            "schema": {
              "type": "string",
              "example": "77777777777"
            }
          },
          {
            "name": "noticeId",
            "in": "path",
            "required": true,
            "description": "Identificatore univoco dell'avviso di pagamento.",
            "schema": {
              "type": "string",
              "example": "311111111111111111"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Opzioni di pagamento recuperate con successo.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "paTaxCode": {
                      "type": "string",
                      "description": "Codice fiscale dell'ente.",
                      "example": "99999000013"
                    },
                    "paFullName": {
                      "type": "string",
                      "description": "Nome completo dell'ente.",
                      "example": "EC"
                    },
                    "paOfficeName": {
                      "type": "string",
                      "description": "Nome dell'ufficio dell'ente.",
                      "example": "EC"
                    },
                    "paymentOptions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "description": {
                            "type": "string",
                            "description": "Descrizione dell'opzione di pagamento.",
                            "example": "Test PayOpt - Opzione 1 - Soluzione Unica"
                          },
                          "numberOfInstallments": {
                            "type": "integer",
                            "description": "Numero di rate disponibili per l'opzione di pagamento.",
                            "example": 1
                          },
                          "amount": {
                            "type": "number",
                            "format": "float",
                            "description": "Importo totale dell'opzione di pagamento.",
                            "example": 120
                          },
                          "dueDate": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Data di scadenza dell'opzione di pagamento.",
                            "example": "2024-10-30T23:59:59"
                          },
                          "validFrom": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Data di validità dell'opzione di pagamento.",
                            "example": "2024-09-30T23:59:59"
                          },
                          "status": {
                            "type": "string",
                            "description": "Stato dell'opzione di pagamento.",
                            "example": "non pagato"
                          },
                          "status_reason": {
                            "type": "string",
                            "description": "Motivo dello stato.",
                            "example": "desc"
                          },
                          "allCCP": {
                            "type": "boolean",
                            "description": "Indicatore se tutte i trasferimenti sono relativi a conti correnti postali.",
                            "example": "false"
                          },
                          "installments": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "nav": {
                                  "type": "string",
                                  "description": "Numero dell'avviso di pagamento.",
                                  "example": "311111111111111116"
                                },
                                "iuv": {
                                  "type": "string",
                                  "description": "Identificativo univoco di versamento.",
                                  "example": "311111111111111116"
                                },
                                "amount": {
                                  "type": "number",
                                  "format": "float",
                                  "description": "Importo della rata.",
                                  "example": 120
                                },
                                "description": {
                                  "type": "string",
                                  "description": "Descrizione della rata.",
                                  "example": "Test Opt Inst - soluzione unica"
                                },
                                "dueDate": {
                                  "type": "string",
                                  "format": "date-time",
                                  "description": "Data di scadenza della rata.",
                                  "example": "2024-10-30T23:59:59"
                                },
                                "validFrom": {
                                  "type": "string",
                                  "format": "date-time",
                                  "description": "Data di validità della rata.",
                                  "example": "2024-09-30T23:59:59"
                                },
                                "status": {
                                  "type": "string",
                                  "description": "Stato della rata.",
                                  "example": "non pagato"
                                },
                                "status_reason": {
                                  "type": "string",
                                  "description": "Motivo dello stato della rata.",
                                  "example": "desc"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}